# Environment Configuration for agent-gatefield
# Copy this file to .env and customize

# Database Configuration
DATABASE_URL=postgresql://gatefield:gatefield_prod_password@localhost:5432/gatefield
POSTGRES_USER=gatefield
POSTGRES_PASSWORD=gatefield_prod_password
POSTGRES_DB=gatefield
POSTGRES_PORT=5432

# Optional: Docker overrides
# Use these when running with docker compose
# DATABASE_URL=postgresql://gatefield:gatefield_prod_password@postgres:5432/gatefield

# Embedding Configuration (BGE-M3 / Qdrant stack)
EMBEDDING_PROVIDER=local
EMBEDDING_RUNTIME=llama.cpp
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
# Fallback used when runtime unavailable or model not loaded
EMBEDDING_FALLBACK_MODEL=local-hash-embedding-v1

# Reranker Configuration
RERANKER_ENABLED=true
RERANKER_PROVIDER=local
RERANKER_RUNTIME=llama.cpp
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K_INPUT=50
RERANKER_TOP_K_OUTPUT=10

# Vector Store Configuration
VECTOR_STORE_BACKEND=qdrant
QDRANT_COLLECTION=gatefield_judgments
QDRANT_HOST=localhost
QDRANT_PORT=6333
# Alternative: use in-memory Qdrant for testing
# QDRANT_HOST=:memory:

# Optional: OpenAI API (not required for default stack)
# OPENAI_API_KEY=sk-...
# OPENAI_API_BASE=https://api.openai.com/v1

# Runtime Profiles
# LLAMA_CPP_HOST=localhost
# LLAMA_CPP_PORT=8080
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434

# Review Queue Configuration
REVIEW_QUEUE_PERSISTENCE_PATH=review_queue_data.jsonl

# Threshold Configuration
THRESHOLD_VERSION=v1

# Logging
LOG_LEVEL=INFO

# Development/Production Mode
# Set to "production" for real database connections
# Set to "development" for mock mode (testing without database)
ENV_MODE=development
